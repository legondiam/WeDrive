#应用配置
app:
  port: 8080
#数据库配置
database:
  mysql:
    host: "127.0.0.1"
    port: 3306
    user: "root"
    password: "YOUR-PASSWORD"
  redis:
    host: "127.0.0.1"
    port: 6379
    password: "redis"
#oss配置
minio:
  endpoint: "127.0.0.1:9000"
  access_key: "YOUR-ACCESS-KEY"
  secret_key: "YOUR-SECRET-KEY"
  use_ssl: false                # 本地开发填 false，线上 HTTPS 填 true
  bucket_name: "wedrive"        # 默认桶名称
  location: "us-east-1"         # 桶所在的区域
  upload_timeout: "30s"           # 上传超时时间
rabbitmq:
  host: "127.0.0.1"
  port: 5672
  user: "guest"
  password: "guest"
  vhost: "/"
#jwt配置
jwt:
  SecretKey: "YOUR-SECRET-KEY"
  Issuer: "JwtConfigAdmin"
  AccessTokenExpiration: "10m"
  RefreshTokenExpiration: "168h"
upload_cleanup:
  enabled: true
  interval: "10m"
  expire_after: "24h"
  batch_size: 100
redis_breaker:
  enabled: true
  interval: "10s"
  bucket_period: "1s"
  min_requests: 20
  failure_rate: 0.5
  consecutive_failures: 5
  timeout: "5s"
  half_open_max_requests: 2
